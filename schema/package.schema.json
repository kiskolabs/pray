{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pray.dev/schema/package.schema.json",
  "title": "Pray package specification",
  "description": "Canonical JSON model for a parsed prayspec package declaration.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "name",
    "version",
    "authors",
    "files",
    "exports",
    "skills",
    "templates",
    "adapters",
    "targets",
    "dependencies",
    "metadata"
  ],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": ["string", "null"],
      "minLength": 1
    },
    "description": {
      "type": ["string", "null"],
      "minLength": 1
    },
    "authors": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "license": {
      "type": ["string", "null"],
      "minLength": 1
    },
    "homepage": {
      "type": ["string", "null"],
      "minLength": 1
    },
    "source_code_uri": {
      "type": ["string", "null"],
      "minLength": 1
    },
    "changelog_uri": {
      "type": ["string", "null"],
      "minLength": 1
    },
    "prayfile_version": {
      "type": ["string", "null"],
      "minLength": 1
    },
    "files": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "exports": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/packageExport"
      }
    },
    "skills": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/packageSkill"
      }
    },
    "templates": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/packageTemplate"
      }
    },
    "adapters": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      }
    },
    "targets": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "dependencies": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/packageDependency"
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/literalValue"
      }
    }
  },
  "$defs": {
    "packageExport": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "path"],
      "properties": {
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": ["string", "null"],
          "minLength": 1
        }
      }
    },
    "packageSkill": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path"],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": ["string", "null"],
          "minLength": 1
        }
      }
    },
    "packageTemplate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path"],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": ["string", "null"],
          "minLength": 1
        }
      }
    },
    "packageDependency": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "constraint", "optional"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "constraint": {
          "type": "string",
          "minLength": 1
        },
        "optional": {
          "type": "boolean"
        }
      }
    },
    "literalValue": {
      "oneOf": [
        {
          "type": "object",
          "required": ["String"],
          "additionalProperties": false,
          "properties": {
            "String": {
              "type": "string"
            }
          }
        },
        {
          "type": "object",
          "required": ["Symbol"],
          "additionalProperties": false,
          "properties": {
            "Symbol": {
              "type": "string"
            }
          }
        },
        {
          "type": "object",
          "required": ["Bool"],
          "additionalProperties": false,
          "properties": {
            "Bool": {
              "type": "boolean"
            }
          }
        },
        {
          "type": "object",
          "required": ["Null"],
          "additionalProperties": false,
          "properties": {
            "Null": {
              "type": "null"
            }
          }
        },
        {
          "type": "object",
          "required": ["Integer"],
          "additionalProperties": false,
          "properties": {
            "Integer": {
              "type": "integer"
            }
          }
        },
        {
          "type": "object",
          "required": ["Array"],
          "additionalProperties": false,
          "properties": {
            "Array": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/literalValue"
              }
            }
          }
        },
        {
          "type": "object",
          "required": ["Map"],
          "additionalProperties": false,
          "properties": {
            "Map": {
              "type": "object",
              "additionalProperties": {
                "$ref": "#/$defs/literalValue"
              }
            }
          }
        }
      ]
    }
  }
}
