{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pray.dev/schema/lockfile.schema.json",
  "title": "Prayfile.lock",
  "description": "JSON representation of a Prayfile.lock document. On disk the format is TOML; serde maps the same field names and nesting.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "prayfile_lock",
    "spec",
    "generated_by",
    "manifest_hash",
    "source",
    "package",
    "target",
    "managed_span"
  ],
  "properties": {
    "prayfile_lock": {
      "type": "string",
      "minLength": 1,
      "description": "Lockfile format version."
    },
    "spec": {
      "type": "string",
      "minLength": 1,
      "description": "Pray specification revision that produced this lockfile."
    },
    "generated_by": {
      "type": "string",
      "minLength": 1,
      "description": "Tool name and version that wrote the lockfile."
    },
    "manifest_hash": {
      "$ref": "#/$defs/sha256Digest"
    },
    "source": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/lockSource"
      }
    },
    "package": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/lockedPackage"
      }
    },
    "target": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/lockedTarget"
      }
    },
    "managed_span": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/managedSpanRecord"
      }
    }
  },
  "$defs": {
    "sha256Digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "lockSource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "kind", "url"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "minLength": 1
        },
        "revision": {
          "type": "string",
          "minLength": 1
        },
        "host_key_fingerprint": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "lockedPackage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "version",
        "path",
        "tree_hash",
        "artifact_hash",
        "artifact",
        "exports",
        "dependencies"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "source": {
          "type": ["string", "null"],
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "tree_hash": {
          "$ref": "#/$defs/sha256Digest"
        },
        "artifact_hash": {
          "$ref": "#/$defs/sha256Digest"
        },
        "artifact": {
          "type": "string",
          "minLength": 1,
          "description": "Registry artifact path or path: relative location."
        },
        "exports": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "dependencies": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "signer_fingerprint": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "lockedTarget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "outputs"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "outputs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "managedSpanRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "target",
        "open_line",
        "close_line",
        "ideal_checksum",
        "package",
        "export",
        "source_checksum",
        "silenced"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[0-9a-f]{8}$"
        },
        "target": {
          "type": "string",
          "minLength": 1
        },
        "open_line": {
          "type": "integer",
          "minimum": 1
        },
        "close_line": {
          "type": "integer",
          "minimum": 1
        },
        "ideal_checksum": {
          "$ref": "#/$defs/sha256Digest"
        },
        "package": {
          "type": "string",
          "minLength": 1
        },
        "export": {
          "type": "string",
          "minLength": 1
        },
        "source_checksum": {
          "$ref": "#/$defs/sha256Digest"
        },
        "silenced": {
          "type": "boolean"
        }
      }
    }
  }
}
