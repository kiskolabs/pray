{
  "name": "pray-cli",
  "version": "1.2.0",
  "description": "TypeScript library and CLI for the Prayfile workflow",
  "author": "Andrei Makarov <contact@kiskolabs.com>",
  "license": "MIT",
  "homepage": "https://pray.kisko.dev",
  "bugs": {
    "url": "https://github.com/kiskolabs/pray/issues"
  },
  "type": "module",
  "bin": {
    "pray": "./bin/pray.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "bin",
    "dist",
    "README.md",
    "LICENSE.md",
    "CHANGELOG.md",
    "SECURITY.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "test": "npm run build && tsc -p tsconfig.test.json && node --test 'dist/**/*.test.js'",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "biome check . && npm run lint:cycles",
    "libyears": "libyear --dev --quiet",
    "lint:cycles": "madge --circular --extensions ts --ts-config tsconfig.json src/index.ts src/cli/main.ts",
    "format": "biome format --write .",
    "format:check": "biome format ."
  },
  "dependencies": {
    "semver": "^7.7.2",
    "smol-toml": "^1.3.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@types/node": "^22.15.0",
    "@types/semver": "^7.7.0",
    "libyear": "^0.9.3",
    "madge": "^8.0.0",
    "typescript": "^5.8.3"
  },
  "keywords": [
    "pray",
    "prayfile",
    "agents",
    "inference",
    "package-manager"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kiskolabs/pray.git",
    "directory": "npmjs/pray-cli"
  }
}
